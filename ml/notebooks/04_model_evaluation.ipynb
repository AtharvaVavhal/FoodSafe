   "source": [
    "# Simulated user study data — replace with real survey results\n",
    "# User study: 50 participants in Nagpur, Maharashtra\n",
    "# Groups: 25 with app, 25 without (control)\n",
    "\n",
    "user_study = {\n",
    "    'Metric':                              ['With FoodSafe', 'Without (control)'],\n",
    "    'Correct adulteration identification': [78,               31],\n",
    "    'Changed buying behaviour (%)':        [72,               18],\n",
    "    'Performed home test (%)':             [68,               12],\n",
    "    'Awareness score (0-10)':              [7.8,              4.2],\n",
    "    'Satisfaction score (0-10)':           [8.1,              'N/A'],\n",
    "}\n",
    "\n",
    "df_study = pd.DataFrame(user_study)\n",
    "print(df_study.to_string(index=False))\n",
    "\n",
    "# Statistical significance (chi-square test for behaviour change)\n",
    "from scipy import stats\n",
    "obs = np.array([[72, 28], [18, 82]])   # changed / did not change\n",
    "chi2, p_value, dof, expected = stats.chi2_contingency(obs)\n",
    "print(f'\\nBehaviour change chi-square test:')\n",
    "print(f'chi2 = {chi2:.3f}, p = {p_value:.4f}')\n",
    "print(f'Result: {\"Statistically significant (p<0.05)\" if p_value < 0.05 else \"Not significant\"}')"
   ]
  },
