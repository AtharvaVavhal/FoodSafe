{
  "model": "google/muril-base-cased",
  "description": "Multilingual NLP for Hindi and Marathi food safety queries",
  "labels": {
    "0": "other",
    "1": "adulteration",
    "2": "symptom",
    "3": "brand"
  },
  "training_samples": [
